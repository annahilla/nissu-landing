---
import Layout from '../layouts/Layout.astro';
const params = new URL(Astro.request.url).searchParams;
const userId = params.get('userId');
const secret = params.get('secret');
const projectId = import.meta.env.PUBLIC_APPWRITE_PROJECT_ID;
const endpoint = import.meta.env.PUBLIC_APPWRITE_ENDPOINT;
---

<Layout>
  <div class="h-[80vh] flex items-center justify-center">
    <div
      class="w-full md:w-[50rem] flex flex-col items-center justify-center gap-4 border-brown rounded-lg border-2 px-12 py-17 m-8 text-center"
    >
      <div class="text-4xl">🔐</div>
      <h1 class="text-xl font-semibold">Verifying your email</h1>
      <p id="status">Loading...</p>
    </div>
  </div>
</Layout>

<script type="module" define:vars={{ userId, secret, projectId, endpoint }}>
  import { Client, Account } from 'appwrite';

  const statusEl = document.getElementById('status');

  try {
    if (!userId || !secret) {
      throw new Error('Invalid verification link.');
    }

    const client = new Client().setEndpoint(endpoint).setProject(projectId);

    const account = new Account(client);

    await account.updateVerification(userId, secret);

    statusEl.textContent =
      '✅ Email verified successfully. You can now return to the app.';
  } catch (error) {
    console.error(error);

    statusEl.textContent = `❌ ${error?.message || 'Error verifying email.'}`;
  }
</script>
